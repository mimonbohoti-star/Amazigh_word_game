<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>AWAR-Gⵣ</title>

  <script src="https://cdn.jsdelivr.net/npm/phaser@3/dist/phaser.js"></script>

  <style>
    body {
      margin: 0;
      background: black;
    }
  </style>
</head>

<body>

<script>

// ================= DATA =================
let unlockedLevel = 0;

const savedLevel = localStorage.getItem("unlockedLevel");
if (savedLevel !== null) {
  unlockedLevel = parseInt(savedLevel);
}

const stages = [
  {
    name: "مرحلة ⵣ",
    grid: { cols: 7, rows: 7 },
    layout: [
      { q: 0, col: 0, row: 0, dir: "vertical", length: 3 },
      { q: 1, col: 3, row: 0, dir: "vertical", length: 7 }
    ],
    qs: [
      { a: "ⵄⵎⵉ", text: { ar: "عمودي 1" } },
      { a: "ⵊⵓⴳⴰⴱⴳⴷ", text: { ar: "العمود الأوسط" } }
    ]
  },
  {
    name: "مرحلة 2",
    grid: { cols: 7, rows: 7 },
    layout: [
      { q: 0, col: 0, row: 0, dir: "vertical", length: 3 }
    ],
    qs: [
      { a: "ⴰⵎⵉ", text: { ar: "عمودي" } }
    ]
  }
];

// ================= MENU =================
class MenuScene extends Phaser.Scene {
  constructor() {
    super("Menu");
  }

  create() {
    const centerX = this.cameras.main.width / 2;

    this.add.text(centerX, 200, 'START', {
      fontSize: '40px',
      color: '#00ff00'
    })
    .setOrigin(0.5)
    .setInteractive()
    .on('pointerup', () => {
      this.scene.start("Map");
    });
  }
}

// ================= MAP =================
class MapScene extends Phaser.Scene {
  constructor() {
    super("Map");
  }

  create() {
    const centerX = this.cameras.main.width / 2;

    stages.forEach((stage, i) => {

      const x = centerX + (i - 0.5) * 150;
      const y = this.cameras.main.height - 60;

      const box = this.add.rectangle(x, y, 120, 120, 0x222222)
        .setStrokeStyle(3, 0xffff00)
        .setInteractive();

      this.add.text(x, y, i + 1, {
        fontSize: '32px',
        color: '#ffffff'
      }).setOrigin(0.5);
      box.on('pointerup', () => {
        this.scene.start("Game", { index: i });
      });

    });


  }
}


class GameScene extends Phaser.Scene {
  constructor() {
    super("Game");
  }

  init(data) {
    this.index = data.index || 0;
  }

  create() {

    this.selectedCells = null;
    this.selectedIndex = -1;
    this.currentIndex = 0;
    this.letterButtons = [];

    const stage = stages[this.index];
    if (!stage) return;

    // زر رجوع
    this.add.text(70, 40, "⬅", {
      fontSize: "28px",
      color: "#ffffff"
    })
    .setInteractive()
    .on('pointerup', () => {
      this.scene.start("Map");
    });

    const rows = stage.grid.rows;
    const cols = stage.grid.cols;

    const cellSize = 50;
    const offsetX = this.cameras.main.width / 2 - (cols * cellSize) / 2;
    const offsetY = 120;

    this.gridData = [];

    // matrix
    for (let r = 0; r < rows; r++) {
      this.gridData[r] = [];
      for (let c = 0; c < cols; c++) {
        this.gridData[r][c] = {
          active: false,
          rect: null,
          text: null
        };
      }
    }

    // تفعيل الخلايا
    stage.layout.forEach(item => {
      let col = item.col;
      let row = item.row;

      for (let i = 0; i < item.length; i++) {
        if (this.gridData[row] && this.gridData[row][col]) {
          this.gridData[row][col].active = true;
        }

        if (item.dir === "vertical") row++;
        else col++;
      }
    });

    // رسم الخلايا
    for (let r = 0; r < rows; r++) {
      for (let c = 0; c < cols; c++) {

        const cell = this.gridData[r][c];
        if (!cell.active) continue;

        const x = offsetX + c * cellSize + cellSize / 2;
        const y = offsetY + r * cellSize + cellSize / 2;

        const rect = this.add.rectangle(
          x, y,
          cellSize - 4,
          cellSize - 4,
          0x222222
        )
        .setStrokeStyle(2, 0xffffff)
        .setInteractive();

        const text = this.add.text(x, y, "", {
          fontSize: "24px",
          color: "#ffffff"
        }).setOrigin(0.5);

        cell.rect = rect;
        cell.text = text;

       // 🟢 ضغط على الخلية = مسح حرف + يرجع للوحة
rect.on('pointerdown', () => {

  if (!this.selectedCells || !this.selectedCells.includes(cell)) return;

  if (cell.text.text !== "") {

    const removedLetter = cell.text.text;

    // مسح الحرف من الخلية
    cell.text.setText("");

    this.currentIndex = Math.max(0, this.currentIndex - 1);

    // 🔁 رجوع الحرف للوحة
    this.letterButtons.forEach(btn => {
      if (
        btn.text &&
        btn.text.text === removedLetter &&
        btn.used === true
      ) {
        btn.setVisible(true);
        btn.text.setVisible(true);
        btn.used = false;
      }
    });

  }

});
}}
    // السؤال
    this.questionText = this.add.text(
      this.cameras.main.width / 2,
      60,
      "اختار عمود",
      { fontSize: "26px", color: "#00ffff" }
    ).setOrigin(0.5);

    // اختيار العمود
    stage.layout.forEach((item, index) => {

      let col = item.col;
      let row = item.row;

      const cells = [];

      for (let i = 0; i < item.length; i++) {
        const cell = this.gridData[row][col];
        if (cell && cell.rect) cells.push(cell);

        if (item.dir === "vertical") row++;
        else col++;
      }

cells.forEach(cell => {

  cell.rect.on('pointerup', () => {

    // ❌ نفس العمود → ما نديرو والو
    if (this.selectedIndex === index) return;

    // 🔥 رجوع اللون القديم
    if (this.selectedCells) {
      this.selectedCells.forEach(c => {
        c.rect.setFillStyle(0x222222);
      });
    }

    // 🔥 تلوين العمود الجديد
    cells.forEach(c => c.rect.setFillStyle(0x4444aa));

    this.questionText.setText(stage.qs[index].text.ar);

    this.selectedCells = cells;
    this.selectedIndex = index;
    this.currentIndex = 0;

    // 🔥 مسح غير خلايا هاد العمود
    cells.forEach(c => {
      if (c.text) c.text.setText("");
    });

    // 🔥 إنشاء لوحة جديدة
    this.createLetterPanel(stage.qs[index].a);

  });

});

});
    // عنوان
    this.add.text(this.cameras.main.width / 2, 20, stage.name, {
      fontSize: "28px",
      color: "#ffffff"
    }).setOrigin(0.5);
  }

// ===== لوحة الحروف =====
createLetterPanel(answer) {

  if (!answer) return;

  // 🔥 تنظيف اللوحة القديمة بالكامل
  if (this.letterButtons) {
    this.letterButtons.forEach(btn => {
      if (btn.text) btn.text.destroy();
      btn.destroy();
    });
  }

  this.letterButtons = [];

  let letters = answer.split("");

  const extra = ["ⵣ","ⵔ","ⵙ","ⵢ","ⴷ"];

  // 🔥 إضافة حروف زائدة بدون تكرار
  for (let i = 0; i < 2; i++) {
    let rand = extra[Math.floor(Math.random() * extra.length)];
    if (!letters.includes(rand)) {
      letters.push(rand);
    }
  }

  Phaser.Utils.Array.Shuffle(letters);

  const startX = 60;
  const y = this.cameras.main.height - 80;

  letters.forEach((letter, i) => {

    const btn = this.add.rectangle(
      startX + i * 80,
      y,
      60,
      60,
      0x333333
    )
    .setStrokeStyle(2, 0xffffff)
    .setInteractive();

    const txt = this.add.text(btn.x, btn.y, letter, {
      fontSize: "32px",
      color: "#ffffff"
    }).setOrigin(0.5);

    // ربط النص بالزر
    btn.text = txt;
    btn.used = false;

    btn.on('pointerup', () => {

      if (!this.selectedCells) return;

      const cell = this.selectedCells[this.currentIndex];

      if (cell && !cell.text.text) {

        cell.text.setText(letter);
        this.currentIndex++;

        // 🔥 نخبي الحرف فقط (باش يرجع ملي يتمسح)
        btn.setVisible(false);
        txt.setVisible(false);
        btn.used = true;

      }

    });

    this.letterButtons.push(btn);

  });

}}

// ================= CONFIG =================
new Phaser.Game({
  type: Phaser.AUTO,
  width: 800,
  height: 600,

  scale: {
    mode: Phaser.Scale.FIT,
    autoCenter: Phaser.Scale.CENTER_BOTH
  },

  scene: [MenuScene, MapScene, GameScene]
});

</script>


</body>
</html>
